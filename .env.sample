# Required
GITHUB_REPO_URL="https://github.com/owner/repository"
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional - defaults to "claude"
# CLAUDE_CODE_PATH="/path/to/claude"

# Optional - only needed if using a different account than 'gh auth login'
# GITHUB_PAT="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional - GitHub App authentication (comments appear as the app, not your personal account)
# Create at: https://github.com/settings/apps
# GITHUB_APP_ID="123456"
# GITHUB_APP_SLUG="your-app-slug"
# GITHUB_APP_PRIVATE_KEY_PATH="~/.ssh/your-app.private-key.pem"

# Optional - required only for webhook trigger (adws/triggers/trigger_webhook.ts)
# Generate with: ruby -rsecurerandom -e 'puts SecureRandom.hex(20)'
# or: openssl rand -hex 20
# GITHUB_WEBHOOK_SECRET="your-webhook-secret"

# Optional - directory for storing cloned target repository workspaces (default: ~/.adw/repos)
# TARGET_REPOS_DIR="/path/to/target/repos"

# Optional - maximum concurrent in-progress issues per repository (default: 5)
# MAX_CONCURRENT_PER_REPO=5

# Jira Configuration (required only when using Jira as the issue tracker)
# Jira instance URL (e.g., https://your-domain.atlassian.net)
# JIRA_BASE_URL="https://your-domain.atlassian.net"
# Default Jira project key (e.g., PROJ)
# JIRA_PROJECT_KEY="PROJ"
# Jira Cloud auth: email + API token (https://id.atlassian.net/manage-profile/security/api-tokens)
# JIRA_EMAIL="you@example.com"
# JIRA_API_TOKEN="your-api-token"
# Jira Data Center/Server auth: personal access token (use instead of email + API token)
# JIRA_PAT="your-personal-access-token"

# Optional - show running token totals in issue comments (default: false)
# RUNNING_TOKENS=true

# Optional - show cost breakdowns in GitHub issue/PR comments (default: false)
# SHOW_COST_IN_COMMENTS=true

# GitLab Configuration (required only when using GitLab as the code host)
# GitLab personal access token (needs api scope)
# GITLAB_TOKEN="glpat-xxxxxxxxxxxxxxxxxxxx"
# GitLab instance URL (default: https://gitlab.com, set for self-hosted)
# GITLAB_INSTANCE_URL="https://gitlab.example.com"

# Cloudflare R2 Configuration (required only for screenshot upload functionality)
# CLOUDFLARE_ACCOUNT_ID="your-cloudflare-account-id"
# R2_ACCESS_KEY_ID="your-r2-access-key-id"
# R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"

# Cost API Configuration (required only for D1 cost database writes)
# COST_API_URL="https://costs.paysdoc.nl"
# COST_API_TOKEN="your-cost-api-bearer-token"

# Slack Webhoock for reporting problems/errors (optional)   
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ   