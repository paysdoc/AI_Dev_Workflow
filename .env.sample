# Required
GITHUB_REPO_URL="https://github.com/owner/repository"
ANTHROPIC_API_KEY="sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional - defaults to "claude"
# CLAUDE_CODE_PATH="/path/to/claude"

# Optional - only needed if using a different account than 'gh auth login'
# GITHUB_PAT="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Optional - required only for webhook trigger (adws/triggers/trigger_webhook.ts)
# GITHUB_WEBHOOK_SECRET="your-webhook-secret"

# Optional - directory for storing cloned target repository workspaces (default: ~/.adw/repos)
# TARGET_REPOS_DIR="/path/to/target/repos"

# Optional - maximum concurrent in-progress issues per repository (default: 5)
# MAX_CONCURRENT_PER_REPO=5

# Jira Configuration (required only when using Jira as the issue tracker)
# Jira instance URL (e.g., https://your-domain.atlassian.net)
# JIRA_BASE_URL="https://your-domain.atlassian.net"
# Default Jira project key (e.g., PROJ)
# JIRA_PROJECT_KEY="PROJ"
# Jira Cloud auth: email + API token (https://id.atlassian.net/manage-profile/security/api-tokens)
# JIRA_EMAIL="you@example.com"
# JIRA_API_TOKEN="your-api-token"
# Jira Data Center/Server auth: personal access token (use instead of email + API token)
# JIRA_PAT="your-personal-access-token"

# Optional - show running token totals in issue comments (default: false)
# RUNNING_TOKENS=true
